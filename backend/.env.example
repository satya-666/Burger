NODE_ENV=development
PORT=5000

# Comma-separated frontend origins. Use * only for local testing.
CORS_ORIGIN=http://localhost:3000,https://burger-mu-sooty.vercel.app

# MongoDB Atlas connection string recommended.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/burger?retryWrites=true&w=majority
DB_CONNECTION_TIMEOUT_MS=10000

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# OTP provider: twilio or mock
OTP_PROVIDER=twilio
OTP_EXPIRY_MINUTES=5

# Twilio Verify
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
