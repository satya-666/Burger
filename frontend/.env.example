# Frontend
# Local default proxy target is http://localhost:5001/api.
# On Vercel, set this to your deployed backend API base URL, for example:
# BACKEND_API_URL=https://your-render-service.onrender.com/api
BACKEND_API_URL=http://localhost:5001/api

# Optional: only use this if you want the browser to call the API directly.
# Leaving it empty makes the frontend call /api and use the Next.js proxy.
NEXT_PUBLIC_API_BASE_URL=
